---
const year = new Date().getFullYear();
---
<footer class="mt-20 border-t border-[var(--color-border-soft)] py-10">
  <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 px-6 text-sm text-[var(--color-text-muted)] md:flex-row md:items-center">
    <div class="flex items-center gap-3">
      <img src="/logo.png" alt="" width="28" height="28" class="h-7 w-7 rounded-md" />
      <p>© {year} Hooked · Fangtagebuch in Entwicklung.</p>
    </div>
    <nav aria-label="Rechtliche Links" class="flex gap-5">
      <a href="/impressum" class="hover:text-[var(--color-text-primary)]">Impressum</a>
      <a href="/datenschutz" class="hover:text-[var(--color-text-primary)]">Datenschutz</a>
      <a href="mailto:hello@hooked-fangtagebuch.app" class="hover:text-[var(--color-text-primary)]">Kontakt</a>
    </nav>
  </div>
</footer>
