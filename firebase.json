{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "hooked-fangtagebuch",
          "appId": "1:162244151198:android:533264b45d3baf3245f88f",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "hooked-fangtagebuch",
          "appId": "1:162244151198:ios:8462d1a7a47ed21445f88f",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "hooked-fangtagebuch",
          "configurations": {
            "android": "1:162244151198:android:533264b45d3baf3245f88f",
            "ios": "1:162244151198:ios:8462d1a7a47ed21445f88f"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "database": "default"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "web/dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=()" }
        ]
      },
      {
        "source": "**/*.@(css|js|svg|png|jpg|jpeg|webp|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      },
      {
        "source": "/robots.txt",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ]
  }
}
