// Firestore Security Rules für Hooked
//
// Deployment:
//   firebase deploy --only firestore:rules
//
// Schema:
//   /sharedTrips/{tripId}   — Trip-Daten, eingeloggter Owner schreibt
//   /invites/{token}        — Einladungs-Token (Lesen = jeder eingeloggte)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Geteilte Trips: nur der Owner darf schreiben/löschen.
    // Eingeladene dürfen lesen (Pull-Refresh), aber nicht editieren.
    // Trip-IDs sind UUIDv4 (122 bit Entropie) — nicht ratbar.
    match /sharedTrips/{tripId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerUid == request.auth.uid;

      // Teilnehmer: jeder Auth-User darf seinen eigenen Eintrag
      // anlegen/aktualisieren. Lesen darf jeder Auth-User. Löschen darf
      // man sich selbst — der Trip-Owner darf zusätzlich beliebige
      // Teilnehmer entfernen.
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
                              && participantId == request.auth.uid
                              && request.resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null
                      && (participantId == request.auth.uid
                          || get(/databases/$(database)/documents/sharedTrips/$(tripId))
                                 .data.ownerUid == request.auth.uid);
      }
    }

    // Einladungs-Token: jeder eingeloggte Nutzer darf lesen, nur der
    // Einladungs-Token: jeder eingeloggte Nutzer darf lesen + löschen
    // (Single-Use: Einlöser invalidiert den Token sofort). Update bleibt
    // dem Aussteller vorbehalten. Tokens sind 8 Zeichen aus 32er-Alphabet
    // (≈ 1 Billion Kombinationen) — clientseitig nicht enumerierbar.
    match /invites/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // Collection-Group-Query auf alle `participants`-Subcollections.
    // Wird beim Multi-Device-Login genutzt, um geteilte Trips wieder-
    // herzustellen, in denen der User Teilnehmer ist.
    match /{path=**}/participants/{participantId} {
      allow read: if request.auth != null;
    }

    // Community-Feed: öffentliche Fang-Posts.
    // Lesen: jeder eingeloggte Nutzer (Feed-Stream).
    // Schreiben: nur der Owner (für Inhalt); zusätzlich darf jeder
    // Auth-User die Felder `likedBy` und `likeCount` ändern (Like-Toggle)
    // sowie `commentCount` (atomare Inkrement-Schreibvorgänge beim
    // Hinzufügen/Löschen von Kommentaren).
    match /feed/{postId} {
      allow read: if request.auth != null;
      // Posts erfordern ein Foto (photoUrl muss befüllt sein) und
      // eine korrekt gesetzte userId. Auto-hidden-Felder sind beim
      // Anlegen nicht erlaubt – die werden ausschließlich vom
      // Cloud-Function-Code bzw. Admin gesetzt.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.photoUrl is string
                    && request.resource.data.photoUrl.size() > 0
                    && !('hidden' in request.resource.data.keys())
                    && !('hiddenReason' in request.resource.data.keys());
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      // Owner darf seine eigenen Posts updaten, darf aber den
      // hidden-Status nicht selbst zurücknehmen. Andere User dürfen
      // nur Like-/Comment-Counter modifizieren.
      allow update: if request.auth != null
                    && (
                      (
                        resource.data.userId == request.auth.uid
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasAny(['hidden', 'hiddenReason', 'hiddenAt'])
                      )
                      || request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasOnly(['likedBy', 'likeCount', 'commentCount'])
                    );

      // Kommentare: lesen alle Auth-User, anlegen wer sich als Autor
      // einträgt (Text 1–1000 Zeichen), löschen nur Autor oder
      // Post-Owner.
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000;
        allow update: if request.auth != null
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 1000;
        allow delete: if request.auth != null
                      && (
                        resource.data.userId == request.auth.uid
                        || get(/databases/$(database)/documents/feed/$(postId))
                              .data.userId == request.auth.uid
                      );
      }
    }

    // Moderation: User-Reports.
    // Jeder Auth-User darf einen Report anlegen, sofern er sich selbst
    // als `reporterUid` einträgt. Lesen ist clientseitig gesperrt —
    // Reports werden ausschließlich über die Firebase Console / Admin
    // SDK ausgewertet. Updates/Löschen sind ebenfalls verboten.
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid
                    && request.resource.data.targetType in ['post', 'comment', 'user']
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() < 500;
      allow update, delete: if false;
    }

    // Block-Liste pro User: /userBlocks/{uid} = { blocked: [uid1, uid2, ...] }.
    // Nur der Owner darf seine eigene Liste lesen/schreiben.
    match /userBlocks/{uid} {
      allow read, write: if request.auth != null
                         && uid == request.auth.uid;
    }

    // Aggregierte Reports pro Ziel \u2013 ausschlie\u00dflich vom
    // Cloud-Function-Code (Admin SDK) gepflegt. Clients haben hier
    // keinen Zugriff.
    match /reportAggregates/{key} {
      allow read, write: if false;
    }

    // User-Metadaten f\u00fcrs Server-seitige Rate-Limiting (Sliding-Window).
    // Wird ausschlie\u00dflich von Cloud Functions geschrieben. Der User
    // selbst darf seine eigenen Z\u00e4hler immerhin lesen (z.\u202fB. f\u00fcr eine
    // sp\u00e4tere "Du postest zu schnell"-UI).
    match /userMeta/{uid} {
      allow read: if request.auth != null && uid == request.auth.uid;
      allow write: if false;
    }

    // Tageszähler für SafeSearch-Calls – nur Cloud Functions.
    match /visionUsage/{day} {
      allow read, write: if false;
    }
  }
}
