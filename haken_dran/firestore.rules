rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hilfsfunktionen
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Fragen: alle authentifizierten User dürfen lesen, niemand schreiben (nur Admin/Functions)
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // User-Dokumente: nur der eigene User darf lesen/schreiben
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);

      // Lernfortschritt: Sub-Collection
      match /user_progress/{questionId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // Achievements: Sub-Collection (nur lesen, schreiben via Functions)
      match /user_achievements/{achievementId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow write: if false;
      }
    }

    // Duelle: Teilnehmer dürfen lesen, erstellen; Ergebnis nur via Functions
    match /duels/{duelId} {
      allow read: if isSignedIn() &&
        (resource.data.challenger_id == request.auth.uid ||
         resource.data.challengee_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (resource.data.challenger_id == request.auth.uid ||
         resource.data.challengee_id == request.auth.uid);
      allow delete: if false;
    }

    // Meta (Katalog-Versionen): alle dürfen lesen
    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
